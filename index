<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Claims Leakage Cost Estimator | Sifflet</title>
<script src="https://js.hsforms.net/forms/embed/v2.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --razzmatazz: #FF015D;
    --razzmatazz-dark: #cc004a;
    --ocean: #0040B3;
    --ocean-light: #3366cc;
    --dark: #121922;
    --dark-2: #1a2435;
    --dark-3: #212e42;
    --dark-4: #2a3a52;
    --white: #ffffff;
    --white-60: rgba(255,255,255,0.6);
    --white-30: rgba(255,255,255,0.3);
    --white-10: rgba(255,255,255,0.1);
    --white-06: rgba(255,255,255,0.06);
    --border: rgba(255,255,255,0.12);
    --border-light: rgba(255,255,255,0.07);
    --success: #00d68f;
    --warning: #ffb547;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: var(--dark);
    color: var(--white);
    min-height: 100vh;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* NAV */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 40px;
    border-bottom: 1px solid var(--border-light);
    position: sticky;
    top: 0;
    background: rgba(18,25,34,0.96);
    backdrop-filter: blur(12px);
    z-index: 100;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .logo-mark {
    width: 32px;
    height: 32px;
  }

  .logo-text {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 20px;
    color: var(--white);
    letter-spacing: -0.3px;
  }

  .nav-pill {
    background: var(--white-10);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 6px 16px;
    font-size: 13px;
    color: var(--white-60);
  }

  .nav-cta {
    background: var(--razzmatazz);
    color: var(--white);
    border: none;
    border-radius: 8px;
    padding: 9px 20px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s;
    display: inline-block;
  }

  .nav-cta:hover { background: var(--razzmatazz-dark); }

  /* HERO */
  .hero {
    padding: 72px 40px 56px;
    max-width: 780px;
    margin: 0 auto;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,1,93,0.12);
    border: 1px solid rgba(255,1,93,0.3);
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 12px;
    font-weight: 500;
    color: var(--razzmatazz);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    background: var(--razzmatazz);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  h1 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -1.5px;
    margin-bottom: 20px;
    color: var(--white);
  }

  h1 em {
    font-style: normal;
    color: var(--razzmatazz);
  }

  .hero-sub {
    font-size: 17px;
    color: var(--white-60);
    max-width: 560px;
    margin: 0 auto 12px;
    font-weight: 300;
    line-height: 1.7;
  }

  .hero-note {
    font-size: 13px;
    color: var(--white-30);
    margin-bottom: 0;
  }

  /* MAIN CARD */
  .main {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  .estimator-card {
    background: var(--dark-2);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
  }

  .card-header {
    padding: 28px 36px 24px;
    border-bottom: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .card-header-text h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.3px;
    margin-bottom: 4px;
  }

  .card-header-text p {
    font-size: 13px;
    color: var(--white-60);
  }

  .benchmark-badge {
    background: rgba(0,64,179,0.2);
    border: 1px solid rgba(0,64,179,0.4);
    border-radius: 8px;
    padding: 6px 14px;
    font-size: 12px;
    color: #7ba7ff;
    white-space: nowrap;
  }

  /* SLIDERS */
  .inputs-section {
    padding: 32px 36px;
    border-bottom: 1px solid var(--border-light);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  @media (max-width: 600px) {
    .inputs-section { grid-template-columns: 1fr; gap: 24px; }
    nav { padding: 16px 20px; }
    .hero { padding: 48px 20px 40px; }
    .main { padding: 0 16px 60px; }
    .card-header, .inputs-section, .results-section, .insight-bar, .gate-section { padding-left: 20px; padding-right: 20px; }
  }

  .input-group label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--white-60);
    margin-bottom: 14px;
  }

  .slider-value {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 14px;
    letter-spacing: -0.5px;
    min-height: 36px;
  }

  .slider-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .slider-label {
    font-size: 12px;
    color: var(--white-30);
    white-space: nowrap;
    min-width: 38px;
  }

  .slider-label.right { text-align: right; }

  input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
    flex: 1;
    height: 4px;
    border-radius: 2px;
    background: var(--white-10);
    outline: none;
    cursor: pointer;
  }

  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--razzmatazz);
    cursor: pointer;
    border: 2px solid var(--dark-2);
    box-shadow: 0 0 0 3px rgba(255,1,93,0.2);
    transition: box-shadow 0.15s;
  }

  input[type="range"]::-webkit-slider-thumb:hover {
    box-shadow: 0 0 0 5px rgba(255,1,93,0.25);
  }

  input[type="range"]::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--razzmatazz);
    cursor: pointer;
    border: 2px solid var(--dark-2);
  }

  /* RESULTS */
  .results-section {
    padding: 28px 36px;
    border-bottom: 1px solid var(--border-light);
  }

  .results-label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--white-30);
    margin-bottom: 16px;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 20px;
  }

  @media (max-width: 480px) { .results-grid { grid-template-columns: 1fr; } }

  .result-tile {
    background: var(--dark-3);
    border: 1px solid var(--border-light);
    border-radius: 14px;
    padding: 18px 20px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .result-tile.featured {
    border-color: rgba(255,1,93,0.35);
    background: linear-gradient(135deg, rgba(255,1,93,0.08) 0%, var(--dark-3) 60%);
  }

  .result-tile.featured::before {
    content: 'Industry midpoint';
    position: absolute;
    top: 0;
    right: 0;
    background: var(--razzmatazz);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: white;
    padding: 4px 10px;
    border-radius: 0 14px 0 10px;
  }

  .tile-label {
    font-size: 12px;
    color: var(--white-60);
    margin-bottom: 8px;
  }

  .tile-value {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--white);
  }

  .tile-pct {
    font-size: 13px;
    color: var(--white-30);
    margin-top: 4px;
  }

  /* PAID ROW */
  .paid-row {
    background: rgba(255,181,71,0.07);
    border: 1px solid rgba(255,181,71,0.2);
    border-radius: 12px;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .paid-row-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .paid-icon {
    width: 32px;
    height: 32px;
    background: rgba(255,181,71,0.15);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .paid-icon svg { width: 16px; height: 16px; }

  .paid-text p {
    font-size: 13px;
    color: var(--white-60);
    line-height: 1.4;
  }

  .paid-text strong {
    font-size: 14px;
    color: var(--warning);
    font-weight: 500;
    display: block;
    margin-bottom: 2px;
  }

  .paid-amount {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--warning);
    white-space: nowrap;
    letter-spacing: -0.4px;
  }

  /* INSIGHT BAR */
  .insight-bar {
    padding: 20px 36px;
    border-bottom: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .insight-icon {
    width: 36px;
    height: 36px;
    background: rgba(0,64,179,0.2);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .insight-text {
    font-size: 13px;
    color: var(--white-60);
    line-height: 1.5;
  }

  .insight-text strong {
    color: var(--white);
    font-weight: 500;
  }

  /* GATE SECTION */
  .gate-section {
    padding: 36px 36px 40px;
  }

  .gate-heading {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.3px;
    margin-bottom: 8px;
  }

  .gate-heading em {
    font-style: normal;
    color: var(--razzmatazz);
  }

  .gate-sub {
    font-size: 14px;
    color: var(--white-60);
    margin-bottom: 28px;
    line-height: 1.6;
  }

  /* VALUE PROPS */
  .value-props {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 28px;
  }

  @media (max-width: 560px) { .value-props { grid-template-columns: 1fr; } }

  .vp {
    background: var(--white-06);
    border: 1px solid var(--border-light);
    border-radius: 10px;
    padding: 14px 16px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .vp-icon {
    font-size: 18px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .vp-text {
    font-size: 13px;
    color: var(--white-60);
    line-height: 1.5;
  }

  .vp-text strong {
    display: block;
    color: var(--white);
    font-weight: 500;
    margin-bottom: 2px;
    font-size: 13px;
  }

  /* HUBSPOT FORM */
  #hs-form-wrapper {
    background: var(--dark-3);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
  }

  #hs-form-wrapper .hs-form-field label {
    font-size: 13px !important;
    color: rgba(255,255,255,0.6) !important;
    font-family: 'Plus Jakarta Sans', sans-serif !important;
    font-weight: 400 !important;
    margin-bottom: 6px !important;
    display: block !important;
  }

  #hs-form-wrapper input[type="text"],
  #hs-form-wrapper input[type="email"],
  #hs-form-wrapper input[type="tel"],
  #hs-form-wrapper select {
    background: rgba(255,255,255,0.06) !important;
    border: 1px solid rgba(255,255,255,0.15) !important;
    border-radius: 8px !important;
    color: white !important;
    font-family: 'Plus Jakarta Sans', sans-serif !important;
    font-size: 14px !important;
    padding: 10px 14px !important;
    width: 100% !important;
    outline: none !important;
    transition: border-color 0.15s !important;
    height: auto !important;
  }

  #hs-form-wrapper input:focus,
  #hs-form-wrapper select:focus {
    border-color: rgba(255,1,93,0.5) !important;
  }

  #hs-form-wrapper .hs-button,
  #hs-form-wrapper input[type="submit"] {
    background: var(--razzmatazz) !important;
    color: white !important;
    border: none !important;
    border-radius: 8px !important;
    padding: 13px 28px !important;
    font-family: 'Plus Jakarta Sans', sans-serif !important;
    font-size: 15px !important;
    font-weight: 500 !important;
    cursor: pointer !important;
    width: 100% !important;
    margin-top: 8px !important;
    transition: background 0.15s !important;
    letter-spacing: 0 !important;
  }

  #hs-form-wrapper .hs-button:hover { background: var(--razzmatazz-dark) !important; }

  #hs-form-wrapper .hs-form-field { margin-bottom: 16px !important; }

  #hs-form-wrapper .inputs-list { list-style: none !important; padding: 0 !important; }

  #hs-form-wrapper .hs-error-msgs {
    list-style: none !important;
    padding: 0 !important;
    margin-top: 4px !important;
  }

  #hs-form-wrapper .hs-error-msgs li {
    font-size: 12px !important;
    color: #ff6b6b !important;
  }

  #hs-form-wrapper .submitted-message {
    color: var(--success) !important;
    font-size: 15px !important;
    padding: 16px 0 !important;
  }

  #hs-form-wrapper fieldset { max-width: 100% !important; border: none !important; padding: 0 !important; }

  #hs-form-wrapper .form-columns-2 .hs-form-field { width: 100% !important; float: none !important; }

  /* PRIVACY NOTE */
  .privacy-note {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 14px;
  }

  .privacy-note svg { width: 14px; height: 14px; opacity: 0.4; flex-shrink: 0; }

  .privacy-note span {
    font-size: 12px;
    color: var(--white-30);
    line-height: 1.4;
  }

  /* SUCCESS STATE */
  #success-state {
    display: none;
    padding: 40px 36px;
    text-align: center;
  }

  .success-icon {
    width: 56px;
    height: 56px;
    background: rgba(0,214,143,0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }

  .success-icon svg { width: 26px; height: 26px; }

  #success-state h3 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 10px;
    letter-spacing: -0.3px;
  }

  #success-state p {
    font-size: 15px;
    color: var(--white-60);
    max-width: 440px;
    margin: 0 auto 28px;
    line-height: 1.6;
  }

  .success-ctas {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--razzmatazz);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 12px 24px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s;
    display: inline-block;
  }

  .btn-primary:hover { background: var(--razzmatazz-dark); }

  .btn-secondary {
    background: transparent;
    color: var(--white-60);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 24px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    cursor: pointer;
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
    display: inline-block;
  }

  .btn-secondary:hover { border-color: var(--white-30); color: var(--white); }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--border-light);
    padding: 28px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    max-width: 820px;
    margin: 0 auto;
  }

  .footer-left {
    font-size: 13px;
    color: var(--white-30);
  }

  .footer-links {
    display: flex;
    gap: 20px;
  }

  .footer-links a {
    font-size: 13px;
    color: var(--white-30);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-links a:hover { color: var(--white-60); }

  /* STICKY BOTTOM BAR (mobile) */
  .sticky-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(18,25,34,0.97);
    backdrop-filter: blur(12px);
    border-top: 1px solid var(--border);
    padding: 12px 20px;
    z-index: 200;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  @media (max-width: 600px) { .sticky-bar { display: flex; } }

  .sticky-bar-text { font-size: 13px; color: var(--white-60); }
  .sticky-bar-text strong { color: var(--white); }

  /* ANIMATION */
  .fade-in {
    opacity: 0;
    transform: translateY(16px);
    animation: fadeUp 0.5s ease forwards;
  }

  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .fade-in:nth-child(2) { animation-delay: 0.1s; }
  .fade-in:nth-child(3) { animation-delay: 0.2s; }

  /* NUMBER FLASH */
  @keyframes numFlash {
    0% { opacity: 0.4; }
    100% { opacity: 1; }
  }

  .num-update { animation: numFlash 0.25s ease; }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="https://www.siffletdata.com" class="nav-logo" target="_blank" rel="noopener">
    <img src="data:image/png;base64," alt="Sifflet" style="height:28px; width:auto; display:block; filter: brightness(0) invert(1);">
  </a>
  <span class="nav-pill">For Insurance</span>
  <a href="https://www.siffletdata.com/contact-us" class="nav-cta" target="_blank" rel="noopener">Talk to us</a>
</nav>

<!-- HERO -->
<section class="hero fade-in">
  <div class="eyebrow">
    <span class="eyebrow-dot"></span>
    Claims Leakage Estimator
  </div>
  <h1>How much is <em>leaving</em><br>before anyone notices?</h1>
  <p class="hero-sub">Most insurers catch data issues after the claim has been paid. Enter your numbers to see what that costs you — based on published industry benchmarks.</p>
  <p class="hero-note">Takes 20 seconds. No login required.</p>
</section>

<!-- MAIN -->
<main class="main">
  <div class="estimator-card fade-in">

    <!-- CARD HEADER -->
    <div class="card-header">
      <div class="card-header-text">
        <h2>Your leakage exposure</h2>
        <p>Adjust the sliders to match your business</p>
      </div>
      <div class="benchmark-badge">Based on P&amp;C industry benchmarks (5–10%)</div>
    </div>

    <!-- SLIDERS -->
    <div class="inputs-section">
      <div class="input-group">
        <label>Annual claims volume</label>
        <div class="slider-value" id="vol-display">50,000 claims</div>
        <div class="slider-row">
          <span class="slider-label">1K</span>
          <input type="range" id="volume" min="1000" max="500000" step="1000" value="50000" oninput="update()">
          <span class="slider-label right">500K</span>
        </div>
      </div>
      <div class="input-group">
        <label>Average claim value</label>
        <div class="slider-value" id="val-display">$8,000</div>
        <div class="slider-row">
          <span class="slider-label">$500</span>
          <input type="range" id="avgval" min="500" max="50000" step="500" value="8000" oninput="update()">
          <span class="slider-label right">$50K</span>
        </div>
      </div>
    </div>

    <!-- RESULTS -->
    <div class="results-section">
      <p class="results-label">Estimated annual leakage exposure</p>
      <div class="results-grid">
        <div class="result-tile">
          <div class="tile-label">Conservative</div>
          <div class="tile-value" id="low">$20M</div>
          <div class="tile-pct">5% of claims spend</div>
        </div>
        <div class="result-tile featured">
          <div class="tile-label">Midpoint</div>
          <div class="tile-value" id="mid">$30M</div>
          <div class="tile-pct">7.5% of claims spend</div>
        </div>
        <div class="result-tile">
          <div class="tile-label">High end</div>
          <div class="tile-value" id="high">$40M</div>
