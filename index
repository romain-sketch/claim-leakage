<script>
  function fmtMoney(n) {
    if (n >= 1e9) return '$' + (Math.round(n / 1e8) / 10).toFixed(1) + 'B';
    if (n >= 1e6) return '$' + Math.round(n / 1e6) + 'M';
    if (n >= 1e3) return '$' + Math.round(n / 1e3) + 'K';
    return '$' + Math.round(n).toLocaleString();
  }

  function fmtNum(n) {
    return n >= 1000 ? (n / 1000).toFixed(n % 1000 === 0 ? 0 : 1) + 'K' : n.toString();
  }

  function flash(id) {
    var el = document.getElementById(id);
    el.classList.remove('num-update');
    void el.offsetWidth;
    el.classList.add('num-update');
  }

  function update() {
    var vol = parseInt(document.getElementById('volume').value);
    var val = parseInt(document.getElementById('avgval').value);

    document.getElementById('vol-display').textContent = vol.toLocaleString() + ' claims';
    document.getElementById('val-display').textContent = '$' + val.toLocaleString();

    var total = vol * val;
    var low = total * 0.05;
    var mid = total * 0.075;
    var high = total * 0.10;
    var paidMid = mid * 0.70;

    document.getElementById('low').textContent = fmtMoney(low);
    document.getElementById('mid').textContent = fmtMoney(mid);
    document.getElementById('high').textContent = fmtMoney(high);
    document.getElementById('paid-mid').textContent = fmtMoney(paidMid);
    document.getElementById('sticky-mid').textContent = fmtMoney(mid);

    ['low','mid','high','paid-mid'].forEach(flash);
  }

  update();

  // HubSpot form
  window.addEventListener('load', function() {
    if (window.hbspt) {
      hbspt.forms.create({
        region: "eu1",               // update if your portal is US
        portalId: "24383351",
        formId: "YOUR_FORM_ID_HERE", // replace with your insurance form GUID
        target: "#hs-form-target",
        onFormSubmitted: function() {
          document.getElementById('gate-section').style.display = 'none';
          document.getElementById('success-state').style.display = 'block';
          document.getElementById('sticky-bar').style.display = 'none';
        }
      });
    }
  });

  // Sticky bar scroll behaviour
  var stickyBar = document.getElementById('sticky-bar');
  var gateSection = document.getElementById('gate-section');

  window.addEventListener('scroll', function() {
    if (window.innerWidth <= 600) {
      var gateTop = gateSection.getBoundingClientRect().top;
      stickyBar.style.display = gateTop < 0 ? 'none' : 'flex';
    }
  });
</script>

